[submodule ".registry"]
	path = .registry
	url = https://github.com/r-universe-org/cran-to-git
	shallow = true
	branch = HEAD
[submodule "hsdar"]
	path = hsdar
	url = https://github.com/cran/hsdar
	shallow = true
	registered = true
[submodule "msaFACE"]
	path = msaFACE
	url = https://github.com/cran/msaFACE
	shallow = true
	registered = true
